{
  "manifest_version": 3,
  "name": "Skool Classroom Intake",
  "version": "1.0",
  "description": "Scrape, transcribe, and screenshot the current Skool classroom into agent-readable intake.",
  "permissions": ["cookies", "tabs", "storage", "sidePanel"],
  "host_permissions": [
    "https://*.skool.com/*",
    "http://127.0.0.1:8765/*",
    "http://localhost:8765/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Skool Intake",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "side_panel": {
    "default_path": "popup.html"
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
