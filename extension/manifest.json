{
  "manifest_version": 3,
  "name": "Skool Classroom Intake",
  "version": "1.0",
  "description": "Scrape, transcribe, and screenshot the current Skool classroom into agent-readable intake.",
  "permissions": ["cookies", "tabs", "storage"],
  "host_permissions": [
    "https://*.skool.com/*",
    "http://127.0.0.1:8765/*",
    "http://localhost:8765/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Skool Intake"
  }
}
